# Lizard SIMULA configuration.
# Copy to `.env` and edit as desired; python-dotenv loads it at startup.

# Root directory for the SQLite DB, reports and configs.
LIZARD_HOME=~/.lizard

# Ollama configuration. Leave OLLAMA_HOST empty to use the default
# (http://localhost:11434). If Ollama is offline, Lizard falls back to a
# deterministic reasoning stub so every command still works.
OLLAMA_HOST=
OLLAMA_MODEL=gemma3

# Force-skip Ollama entirely (use only the deterministic fallback). Useful
# for CI, tests, and flights. Accepts 1, true, yes, on.
LIZARD_DISABLE_OLLAMA=

# Default number of agents per simulation (must be in [5, 28]).
LIZARD_AGENT_COUNT=7

# Maximum number of SIMULA steps per run.
LIZARD_MAX_STEPS=8

# Boltzmann temperature for thermodynamic action selection (>0).
LIZARD_TEMPERATURE=1.0

# Random seed for reproducible runs. Leave empty for a fresh seed each run.
LIZARD_SEED=

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LIZARD_LOG_LEVEL=INFO
